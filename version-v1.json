        {
            "parameters": {
                "jsCode": "// Validate email format and trim whitespace\nconst items = $input.all();\nconst results = [];\n\nfor (const item of items) {\n  const email = (item.json.email || '').toString().trim();\n  const regex = /^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$/;\n  const isValid = regex.test(email);\n\n  results.push({\n    json: {\n      ...item.json,\n      email: email,\n      email_valid: isValid\n    }\n  });\n}\n\nreturn results;"
            },
            "id": "a1000001-0001-4001-8001-000000000005",
            "name": "Validate Email",
            "type": "n8n-nodes-base.code",
            "typeVersion": 2,
            "position": [
                1120,
                300
            ]
        },
        {
            "parameters": {
                "conditions": {
                    "options": {
                        "caseSensitive": true,
                        "leftValue": "",
                        "typeValidation": "strict"
                    },
                    "conditions": [
                        {
                            "id": "cond-email-valid",
                            "leftValue": "={{ $json.email_valid }}",
                            "rightValue": "",
                            "operator": {
                                "type": "boolean",
                                "operation": "true"
                            }
                        }
                    ],
                    "combinator": "and"
                },
                "options": {}
            },
            "id": "a1000001-0001-4001-8001-000000000006",
            "name": "Is Email Valid?",
