        {
            "parameters": {
                "fromEmail": "YOUR_HOSTINGER_SENDER_EMAIL@domain.com",
                "toEmail": "={{ $('Prepare Document Data').first().json.email }}",
                "subject": "=Offer Letter — {{ $('Prepare Document Data').first().json.name }} — Samriddhi Anveshana",
                "emailType": "html",
                "html": "=<div style=\"font-family: 'Segoe UI', Arial, sans-serif; max-width: 600px; margin: 0 auto; padding: 20px;\">\n  <div style=\"background: linear-gradient(135deg, #1a237e, #283593); padding: 30px; border-radius: 12px 12px 0 0; text-align: center;\">\n    <h1 style=\"color: #ffffff; margin: 0; font-size: 24px;\">Samriddhi Anveshana</h1>\n  </div>\n  <div style=\"background: #ffffff; padding: 30px; border: 1px solid #e0e0e0; border-top: none; border-radius: 0 0 12px 12px;\">\n    <p style=\"font-size: 16px; color: #333;\">Dear <strong>{{ $('Prepare Document Data').first().json.name }}</strong>,</p>\n    <p style=\"font-size: 15px; color: #555; line-height: 1.6;\">We are delighted to extend an offer for the position of <strong>{{ $('Prepare Document Data').first().json.role }}</strong> at Samriddhi Anveshana.</p>\n    <p style=\"font-size: 15px; color: #555; line-height: 1.6;\">Please find your official offer letter attached to this email. Kindly review the terms and conditions outlined in the document.</p>\n    <p style=\"font-size: 15px; color: #555; line-height: 1.6;\">Your joining date is <strong>{{ $('Prepare Document Data').first().json.start_date }}</strong>. If you have any questions, feel free to reach out.</p>\n    <hr style=\"border: none; border-top: 1px solid #e0e0e0; margin: 25px 0;\">\n    <p style=\"font-size: 14px; color: #777;\">Warm regards,<br><strong>Sahana</strong><br>HR Department<br>Samriddhi Anveshana<br><a href=\"mailto:Sahanauppala@samriddhianveshana.in\" style=\"color: #1a237e;\">Sahanauppala@samriddhianveshana.in</a></p>\n  </div>\n</div>",
                "options": {
                    "attachments": "data"
                }
            },
