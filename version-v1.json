        {
            "parameters": {
                "jsCode": "// Merge the original employee data with the new document ID\n// This prevents data loss from Google Drive Copy overwriting payload\nconst originalData = $('Validate Email').first().json;\nconst copyResult = $input.first().json;\n\nreturn [{\n  json: {\n    name: originalData.name,\n    email: originalData.email,\n    phone_number: originalData.phone_number || '',\n    role: originalData.role,\n    department: originalData.department || '',\n    salary: originalData.salary,\n    start_date: originalData.start_date,\n    reporting_manager: originalData.reporting_manager,\n    row_number: originalData.row_number,\n    newDocId: copyResult.id,\n    newDocName: copyResult.name\n  }\n}];"
            },
            "id": "a1000001-0001-4001-8001-000000000009",
            "name": "Prepare Document Data",
            "type": "n8n-nodes-base.code",
            "typeVersion": 2,
            "position": [
                1780,
                300
            ]
        },
        {
            "parameters": {
                "operation": "update",
                "documentId": "={{ $json.newDocId }}",
                "actionsUi": {
                    "actionFields": [
                        {
                            "action": "replaceAllText",
                            "findText": "{{name}}",
                            "replaceText": "={{ $json.name }}",
                            "matchCase": false
                        },
                        {
                            "action": "replaceAllText",
                            "findText": "{{role}}",
                            "replaceText": "={{ $json.role }}",
                            "matchCase": false
                        },
                        {
                            "action": "replaceAllText",
                            "findText": "{{salary}}",
                            "replaceText": "={{ $json.salary }}",
                            "matchCase": false
                        },
                        {
                            "action": "replaceAllText",
                            "findText": "{{joining_date}}",
                            "replaceText": "={{ $json.start_date }}",
                            "matchCase": false
                        },
                        {
                            "action": "replaceAllText",
                            "findText": "{{reporting_manager}}",
                            "replaceText": "={{ $json.reporting_manager }}",
                            "matchCase": false
                        },
                        {
                            "action": "replaceAllText",
                            "findText": "{{hr_name}}",
                            "replaceText": "Sahana",
                            "matchCase": false
                        },
                        {
                            "action": "replaceAllText",
                            "findText": "{{hr_email}}",
                            "replaceText": "Sahanauppala@samriddhianveshana.in",
                            "matchCase": false
                        }
                    ]
                },
                "simple": false
            },
            "id": "a1000001-0001-4001-8001-000000000010",
